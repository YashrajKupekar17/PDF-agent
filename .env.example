# Copy to .env and fill in. Never commit .env.

# OpenAI
OPENAI_API_KEY=

# Pinecone (https://app.pinecone.io — free tier OK)
PINECONE_API_KEY=
PINECONE_INDEX=pdf-agent

# Cohere (reranker — free tier OK; https://dashboard.cohere.com/api-keys)
COHERE_API_KEY=

# Optional: LangSmith for tracing (https://smith.langchain.com — free tier OK)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pdf-agent

# Runtime
LOG_LEVEL=INFO
ENV=dev
